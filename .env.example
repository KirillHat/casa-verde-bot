# ============================================================================
# Casa Verde Realty — WhatsApp AI Lead Bot
# Copy to .env and fill in real values. Never commit .env to git.
# ============================================================================

# --- Twilio WhatsApp (sandbox or production) --------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Anthropic Claude -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# --- Google Sheets CRM ------------------------------------------------------
# Service-account JSON key with edit access to the sheet (see docs/google_sheets_setup.md)
GOOGLE_CREDENTIALS_JSON=./google_credentials.json
GOOGLE_SHEETS_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_SHEETS_TAB=Leads

# --- Slack notifications (optional) -----------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXX
SLACK_NOTIFY_ENABLED=true
SLACK_NOTIFY_MIN_SCORE=WARM   # HOT | WARM | COLD

# --- Application ------------------------------------------------------------
APP_BASE_URL=https://casaverde-bot.onrender.com
DATABASE_URL=sqlite+aiosqlite:///./data/leads.db
LOG_LEVEL=INFO
ENVIRONMENT=development     # development | staging | production
DEBUG_SKIP_TWILIO_SIGNATURE=false   # only true for local development

# --- Observability (optional) -----------------------------------------------
SENTRY_DSN=

# --- Business config (Casa Verde Realty) ------------------------------------
BUSINESS_NAME=Casa Verde Realty
BUSINESS_TIMEZONE=America/Los_Angeles
BUSINESS_PHONE_DISPLAY=+1 (310) 555-0142
LEAD_SCORE_HOT_THRESHOLD=80
LEAD_SCORE_WARM_THRESHOLD=50
